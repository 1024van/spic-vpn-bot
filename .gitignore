._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Bot specific
bot.session
*.session
*.session-journal
backups/
data/
temp/
tmp/
.cache/
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json

# Security - keys and certificates
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
id_*
