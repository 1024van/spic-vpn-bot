cat > /opt/vpn_bot/.env.example << 'EOF'
# Telegram Bot
BOT_TOKEN=your_bot_token_from_botfather
ADMIN_IDS=123456789,987654321

# TrustTunnel Server
TRUSTTUNNEL_ENDPOINT_PATH=/opt/trusttunnel
TRUSTTUNNEL_DOMAIN=stop2virus.xyz
TRUSTTUNNEL_PUBLIC_IP=185.236.24.249

# FreeKassa (основной платёжный метод)
FREEKASSA_ENABLED=true
FREEKASSA_MERCHANT_ID=your_merchant_id
FREEKASSA_SECRET1=your_secret1
FREEKASSA_SECRET2=your_secret2

# ЮKassa (опционально, отключено по умолчанию)
YOOKASSA_ENABLED=false
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Database
DATABASE_PATH=/opt/vpn_bot/spic.db

# Optional: Webhook URL для платежей
WEBHOOK_URL=https://stop2virus.xyz/webhook
